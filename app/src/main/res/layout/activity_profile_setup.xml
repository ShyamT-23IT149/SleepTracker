<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/project_bg"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="22dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:background="@drawable/panel_bg"
            android:orientation="vertical"
            android:padding="20dp">

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="Profile Details"
                android:textColor="@color/surface_light"
                android:textSize="24sp"
                android:textStyle="bold" />

            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginTop="8dp"
                android:text="Enter your details and preferred sleep hours after login/sign up."
                android:textColor="@color/soft_text" />

            <EditText
                android:id="@+id/etName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="18dp"
                android:background="@drawable/input_bg"
                android:hint="Full Name"
                android:padding="14dp"
                android:textColor="@color/surface_light"
                android:textColorHint="@color/soft_text" />

            <EditText
                android:id="@+id/etEmail"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/input_bg"
                android:hint="Email"
                android:inputType="textEmailAddress"
                android:padding="14dp"
                android:textColor="@color/surface_light"
                android:textColorHint="@color/soft_text" />

            <EditText
                android:id="@+id/etPhone"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/input_bg"
                android:hint="Phone Number"
                android:inputType="phone"
                android:padding="14dp"
                android:textColor="@color/surface_light"
                android:textColorHint="@color/soft_text" />

            <EditText
                android:id="@+id/etSleepHours"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/input_bg"
                android:hint="Preferred Sleep Hours"
                android:inputType="number"
                android:padding="14dp"
                android:textColor="@color/surface_light"
                android:textColorHint="@color/soft_text" />

            <EditText
                android:id="@+id/etFriendName"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:background="@drawable/input_bg"
                android:hint="Friend Name for Birthday Reminder"
                android:padding="14dp"
                android:textColor="@color/surface_light"
                android:textColorHint="@color/soft_text" />

            <TextView
                android:id="@+id/tvBirthdayValue"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="14dp"
                android:textColor="@color/accent_gold"
                android:textStyle="bold" />

            <Button
                android:id="@+id/btnPickBirthday"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="10dp"
                android:text="Pick Friend Birthday Date &amp; Time" />

            <Button
                android:id="@+id/btnSaveProfile"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:backgroundTint="@color/accent_mint"
                android:text="Save and Continue"
                android:textColor="@color/deep_navy" />
        </LinearLayout>
    </LinearLayout>
</ScrollView>
